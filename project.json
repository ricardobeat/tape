{
  "langrev": "1",
  "warnings": [
    "all"
  ],
  "c-sources": [
    "libregexp/libregexp.c",
    "libregexp/libunicode.c",
    "libregexp/re_wrapper.c",
    "libregexp/unicode_wrapper.c",
    "quickjs/cutils.c",
    "quickjs/dtoa.c",
    "src/dtoa_wrapper.c",
    "src/date_math.c"
  ],
  "c-include-dirs": [
    "quickjs",
    "libregexp"
  ],
  "targets": {
    "duktape_c3": {
      "type": "executable",
      "sources": [
        "src",
        "cli/duktape_c3.c3"
      ],
      "opt": "O2",
      "single-module": true,
      "fp-math": "relaxed",
      "panic-msg": false,
      "debug-info": "none"
    },
    "duktape_c3_debug": {
      "type": "executable",
      "sources": [
        "src",
        "cli/duktape_c3_debug.c3"
      ],
      "opt": "O2",
      "single-module": true,
      "fp-math": "relaxed",
      "panic-msg": false,
      "debug-info": "line-tables",
      "features": [
        "TRACE_VM"
      ]
    },
    "duktape_c3_asan": {
      "type": "executable",
      "sources": [
        "src",
        "cli/duktape_c3.c3"
      ],
      "opt": "O0",
      "single-module": true,
      "sanitize": "address"
    },
    "duktape_c3_envstrict": {
      "type": "executable",
      "sources": [
        "src",
        "cli/duktape_c3.c3"
      ],
      "opt": "O0",
      "features": [
        "ENV_STRICT"
      ]
    },
    "lib": {
      "type": "static-lib",
      "sources": [
        "src"
      ]
    },
    "test262_runner": {
      "type": "executable",
      "sources": [
        "src",
        "cli/test262_runner.c3"
      ],
      "opt": "O2",
      "single-module": true
    },
    "test262_runner_asan": {
      "type": "executable",
      "sources": [
        "src",
        "cli/test262_runner.c3"
      ],
      "opt": "O0",
      "single-module": true,
      "sanitize": "address"
    },
    "test_prop": {
      "type": "executable",
      "sources": [
        "src",
        "benchmarks/test_prop.c3"
      ],
      "opt": "O0"
    },
    "test_closure_put": {
      "type": "executable",
      "sources": [
        "src",
        "benchmarks/test_closure_put.c3"
      ],
      "opt": "O0"
    }
  }
}